{
  "name": "@avatardesk/api",
  "version": "0.0.0",
  "private": true,
  "description": "AvatarDesk REST API — tenant auth, widget-session token issuance, knowledge upload, conversation persistence.",
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
