{
  "name": "avatardesk",
  "version": "0.0.0",
  "private": true,
  "description": "AvatarDesk — White-Label B2B-SaaS-Plattform für KI-gestützten Customer Service mit fotorealistischem Video-Avatar.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.3"
  }
}
