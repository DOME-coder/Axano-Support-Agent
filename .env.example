# ─────────────────────────────────────────────────────────────
# AvatarDesk — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# Kopiere diese Datei nach `.env` und trage die echten Werte ein.
# `.env` ist in .gitignore und darf NIEMALS committet werden.
# ─────────────────────────────────────────────────────────────


# ─── App Allgemein ───────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
APP_BASE_URL=http://localhost:3000
API_PORT=3000
DASHBOARD_URL=http://localhost:3001
WIDGET_CDN_URL=http://localhost:5173

# Eindeutige App-Secret für JWT-Signaturen, Cookie-Encryption etc.
# Generieren z.B. mit: openssl rand -hex 32
APP_SECRET=change-me-to-a-random-32-byte-hex-string


# ─── Datenbank (PostgreSQL + pgvector) ───────────────────────
DATABASE_URL=postgresql://avatardesk:avatardesk@localhost:5432/avatardesk
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Optional — überschreibt die Defaults in docker-compose.yml.
# Wenn du diese Werte änderst, halte DATABASE_URL oben synchron.
POSTGRES_USER=avatardesk
POSTGRES_PASSWORD=avatardesk
POSTGRES_DB=avatardesk
POSTGRES_PORT=5432


# ─── Redis (Cache + Queue) ───────────────────────────────────
REDIS_URL=redis://localhost:6379

# Optional — überschreibt den Default-Port in docker-compose.yml.
REDIS_PORT=6379


# ─── Beyond Presence (Avatar-Streaming) ──────────────────────
# Account erstellen unter: https://www.beyondpresence.ai
# API-Key in der BP-Dashboard generieren.
BEY_API_KEY=
BEY_API_BASE_URL=https://api.bey.dev
# Default-Avatar-ID (falls Tenant keine eigene gewählt hat)
BEY_DEFAULT_AVATAR_ID=


# ─── LiveKit (WebRTC SFU) ────────────────────────────────────
# Cloud-Account: https://cloud.livekit.io  (alternativ self-hosted)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=


# ─── Anthropic Claude (LLM) ──────────────────────────────────
# API-Key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL_VISION=claude-sonnet-4-6


# ─── OpenAI (Embeddings + optional Vision-Fallback) ──────────
# API-Key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large


# ─── ElevenLabs (Text-to-Speech) ─────────────────────────────
# API-Key: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_DEFAULT_VOICE_ID=


# ─── Deepgram (Speech-to-Text) ───────────────────────────────
# API-Key: https://console.deepgram.com
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2


# ─── Authentication (Dashboard) ──────────────────────────────
# Wenn NextAuth genutzt wird:
NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=change-me-to-a-random-32-byte-hex-string

# OAuth-Provider (optional, je nach Setup)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=


# ─── Stripe (Billing) ────────────────────────────────────────
# Phase 3+; in Phase 0/1 noch leer lassen.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=


# ─── Observability ───────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development


# ─── Feature Flags ───────────────────────────────────────────
FEATURE_SCREEN_SHARING=true
FEATURE_HUMAN_ESCALATION=false
FEATURE_CUSTOM_AVATAR_UPLOAD=false


# ─── Storage (für PDFs & Knowledge-Base-Uploads) ─────────────
# In Dev: lokales Verzeichnis. In Prod: S3-kompatibel.
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage
# Falls STORAGE_DRIVER=s3:
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=


# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_PER_TENANT_PER_MINUTE=60
RATE_LIMIT_PER_IP_PER_MINUTE=30


# ─── Agent-spezifisch (Python-Service) ───────────────────────
AGENT_LOG_LEVEL=INFO
AGENT_MAX_CONVERSATION_DURATION_MINUTES=30
AGENT_VAD_THRESHOLD=0.5
